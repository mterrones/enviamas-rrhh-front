# Copy to .env and adjust if your Laravel API runs elsewhere.
# Must match the OpenAPI `servers` URL (path includes /api/v1).
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Literal "true" shows "Continuar con Google". Backend needs GOOGLE_* + SSO_ALLOWED_DOMAIN + Google Cloud OAuth client; restart dev server after changes.
VITE_GOOGLE_AUTH_ENABLED=true

# FRONTEND_URL in the Laravel .env must match this app’s origin (this repo: http://localhost:8080 per vite.config.ts).

# Milliseconds without user activity before automatic logout (min 60000, max 86400000). Default 1800000 (30 min).
# VITE_INACTIVITY_LOGOUT_MS=1800000
